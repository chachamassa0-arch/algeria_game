import 'package:flutter/material.dart';

void main() {
  runApp(AlgeriaAdventureApp());
}

class GameState {
  static int coins = 500;
  static int score = 0;
  static int xp = 0;
  static int level = 1;
  static String avatar = "🧑‍🚀";

  static void addXP(int amount) {
    xp += amount;
    if (xp >= level * 200) {
      xp = 0;
      level++;
    }
  }
}

class AlgeriaAdventureApp extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      debugShowCheckedModeBanner: false,
      title: 'مغامر الجزائر',
      theme: ThemeData(primarySwatch: Colors.green),
      home: MainMapScreen(),
    );
  }
}

class MainMapScreen extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return Scaffold(
      body: Stack(
        children: [
          Container(
            decoration: BoxDecoration(
              gradient: LinearGradient(
                colors: [Colors.blue.shade200, Colors.blue.shade50],
                begin: Alignment.topCenter,
              ),
            ),
          ),

          Positioned(top: 150, left: 140, child: levelNode(context, "العاصمة")),
          Positioned(top: 320, left: 80, child: levelNode(context, "وهران")),
          Positioned(top: 520, left: 200, child: levelNode(context, "الصحراء")),

          Positioned(
            top: 60,
            left: 20,
            right: 20,
            child: buildTopBar(),
          ),
        ],
      ),
    );
  }

  Widget levelNode(BuildContext context, String title) {
    return GestureDetector(
      onTap: () {
        Navigator.push(
          context,
          MaterialPageRoute(builder: (_) => QuizScreen(title: title)),
        );
      },
      child: Column(
        children: [
          Stack(
            alignment: Alignment.center,
            children: [
              CircleAvatar(
                radius: 30,
                backgroundColor: Colors.white,
                child: Icon(Icons.place, color: Colors.green),
              ),
              Positioned(
                bottom: -5,
                child: Text(GameState.avatar, style: TextStyle(fontSize: 18)),
              )
            ],
          ),
          SizedBox(height: 5),
          Text(title, style: TextStyle(color: Colors.black)),
        ],
      ),
    );
  }

  Widget buildTopBar() {
    return Container(
      padding: EdgeInsets.all(10),
      decoration: BoxDecoration(
        gradient: LinearGradient(colors: [Colors.green, Colors.lightGreen]),
        borderRadius: BorderRadius.circular(15),
      ),
      child: Row(
        mainAxisAlignment: MainAxisAlignment.spaceBetween,
        children: [
          Row(
            children: [
              CircleAvatar(child: Text(GameState.avatar)),
              SizedBox(width: 10),
              Text("Level ${GameState.level}",
                  style: TextStyle(color: Colors.white)),
            ],
          ),
          Row(
            children: [
              Icon(Icons.monetization_on, color: Colors.amber),
              Text("${GameState.coins}",
                  style: TextStyle(color: Colors.white)),
            ],
          )
        ],
      ),
    );
  }
}

class QuizScreen extends StatefulWidget {
  final String title;
  QuizScreen({required this.title});

  @override
  _QuizScreenState createState() => _QuizScreenState();
}

class _QuizScreenState extends State<QuizScreen> {
  int index = 0;

  List<Map<String, dynamic>> questions = [
    {
      "q": "من هو مؤسس الدولة الرستمية؟",
      "a": ["عبد الرحمن بن رستم", "يوغرطة", "الأمير عبد القادر"],
      "c": "عبد الرحمن بن رستم"
    },
    {
      "q": "أين تقع وهران؟",
      "a": ["شرق", "غرب", "جنوب"],
      "c": "غرب"
    }
  ];

  void answer(String selected) {
    var correct = questions[index]["c"];
    bool ok = selected == correct;

    if (ok) {
      GameState.score += 100;
      GameState.coins += 50;
      GameState.addXP(50);
    }

    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text(ok ? "🎉 صحيح" : "❌ خطأ"),
        backgroundColor: ok ? Colors.green : Colors.red,
      ),
    );

    setState(() {
      if (index < questions.length - 1) {
        index++;
      } else {
        showDialog(
          context: context,
          builder: (_) => AlertDialog(
            title: Text("انتهى التحدي"),
            content: Text("النقاط: ${GameState.score}"),
          ),
        );
      }
    });
  }

  @override
  Widget build(BuildContext context) {
    var q = questions[index];

    return Scaffold(
      appBar: AppBar(title: Text(widget.title)),
      body: Padding(
        padding: EdgeInsets.all(20),
        child: Column(
          children: [
            LinearProgressIndicator(
              value: (index + 1) / questions.length,
            ),
            SizedBox(height: 20),
            Text(q["q"], style: TextStyle(fontSize: 20)),
            SizedBox(height: 20),

            ...q["a"].map<Widget>((e) {
              return ElevatedButton(
                onPressed: () => answer(e),
                child: Text(e),
              );
            }).toList(),

            Spacer(),
            Text("XP: ${GameState.xp} | Coins: ${GameState.coins}")
          ],
        ),
      ),
    );
  }
}
